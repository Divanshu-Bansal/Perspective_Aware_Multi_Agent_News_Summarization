# =============================================================================
# Example Environment Configuration (env.example)
# =============================================================================
# This file provides a template for required environment variables.
#
# How to use:
# 1. Copy this file → .env
#    cp env.example .env
# 2. Replace placeholder values with your actual API keys
#
# ⚠️ Do NOT commit your .env file to version control.
# =============================================================================


# ─────────────────────────────────────────────────────────────
# News API Configuration
# ─────────────────────────────────────────────────────────────

# NewsAPI (https://newsapi.org)
# Used for fetching general news articles
NEWS_API_KEY=your_newsapi_key_here

# The Guardian API (https://open-platform.theguardian.com/access/)
# Provides structured and high-quality journalism data
GUARDIAN_API_KEY=your_guardian_key_here

# GNews API (https://gnews.io)
# Additional news source (free tier has limitations)
GNEWS_API_KEY=your_gnews_key_here


# ─────────────────────────────────────────────────────────────
# ClearML Configuration (Experiment Tracking)
# ─────────────────────────────────────────────────────────────

# ClearML (https://app.clear.ml)
# Get credentials from:
# Settings → Workspace → Create new credentials

CLEARML_API_ACCESS_KEY=your_clearml_access_key_here
CLEARML_API_SECRET_KEY=your_clearml_secret_key_here

# Default ClearML API host (usually no change needed)
CLEARML_API_HOST=https://api.clear.ml